# PostgreSQL
POSTGRES_DB=velamap
POSTGRES_USER=vela_user
POSTGRES_PASSWORD=vela_secure_pass

# 如果使用外部数据库，设置完整 URL（会覆盖上面的分项配置）
# DATABASE_URL=postgresql://vela_user:vela_secure_pass@postgres/velamap

# Frontend (可选，不用 Supabase 时留空)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CORS
ALLOWED_ORIGIN=https://velamap.com
